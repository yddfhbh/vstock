VSTOCK_BASE_URL=https://virtual-stock.xyz
CHROME_CDP_URL=http://127.0.0.1:9222

DRY_RUN=false
ENABLE_TRADING=true

POLL_MS=10000
SCAN_PAGES=35
PAGE_SIZE=50

BUY_QUANTITY=1
MAX_POSITIONS=3
MAX_CHANGE_RATE_ON_ENTRY=100

TAKE_PROFIT_RATE=1.8
STOP_LOSS_RATE=-1.8
TRADE_COOLDOWN_MS=90000

EVALUATE_TOP_N=70
MAX_BUYS_PER_LOOP=1
BUY_SCORE_THRESHOLD=16

MIN_MOMENTUM_1H=1.5
MAX_MOMENTUM_1H=18
MAX_VOLATILITY_1H=18
MAX_PULLBACK_FROM_HIGH=-1.3

TRAILING_START_RATE=0.9
TRAILING_DROP_RATE=-0.6

BUY_CASH_RESERVE=0
BUY_PRICE_BUFFER_RATE=5
MAX_BUY_CASH_PER_TRADE_RATE=25
MIN_BUY_CASH=8000

MAX_HOLD_MS=240000
TIME_EXIT_PROFIT_RATE=0.4
TIME_EXIT_LOSS_RATE=-0.7
MIN_SHORT_MOMENTUM=1.2

MAX_ENTRY_PRICE=110000
BUY_CONFIRM_COUNT=3
BUY_CONFIRM_WINDOW_MS=90000
MIN_MICRO_MOMENTUM=0.2

PRICE_FETCH_CONCURRENCY=8
CONFIRM_CANDIDATES_N=4
WAIT_LOG_TOP_N=4