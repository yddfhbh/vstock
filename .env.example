VSTOCK_BASE_URL=https://virtual-stock.xyz
CHROME_CDP_URL=http://127.0.0.1:9222

DRY_RUN=false
ENABLE_TRADING=true

POLL_MS=12000
SCAN_PAGES=35
PAGE_SIZE=50

BUY_QUANTITY=1
MAX_POSITIONS=5
MAX_CHANGE_RATE_ON_ENTRY=100

TAKE_PROFIT_RATE=2.0
STOP_LOSS_RATE=-2.5
TRADE_COOLDOWN_MS=60000

EVALUATE_TOP_N=80
MAX_BUYS_PER_LOOP=1
BUY_SCORE_THRESHOLD=13

MIN_MOMENTUM_1H=1.5
MAX_MOMENTUM_1H=20
MAX_VOLATILITY_1H=24
MAX_PULLBACK_FROM_HIGH=-2.5

TRAILING_START_RATE=1.0
TRAILING_DROP_RATE=-0.8

BUY_CASH_RESERVE=0
BUY_PRICE_BUFFER_RATE=5
MAX_BUY_CASH_PER_TRADE_RATE=35
MIN_BUY_CASH=8000

MAX_HOLD_MS=300000
TIME_EXIT_PROFIT_RATE=0.3
TIME_EXIT_LOSS_RATE=-0.8
MIN_SHORT_MOMENTUM=0.8

MAX_ENTRY_PRICE=160000
BUY_CONFIRM_COUNT=2
BUY_CONFIRM_WINDOW_MS=60000
MIN_MICRO_MOMENTUM=-0.3

PRICE_FETCH_CONCURRENCY=8
CONFIRM_CANDIDATES_N=5
WAIT_LOG_TOP_N=5